
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum PartyType {
  CUSTOMER
  SUPPLIER
}

enum BillType {
  CASH
  CREDIT
}

enum BillStatus {
  DRAFT
  CONFIRMED
}

enum PaymentMethod {
  CASH
  CREDIT
  BANK
  CHEQUE
}

enum ChequeStatus {
  AVAILABLE
  USED
  CASHED
}

enum ExpenseModule {
  CHEMICAL
  REXINE
  MATERIAL
  LABOR
  MISC
}

enum ExpenseSource {
  MANUAL
  SYSTEM
}

enum LaborStatus {
  ACTIVE
  FIRED
}

enum LaborDepartment {
  PRESSMAN
  UPPERMAN
  PRINTING
  DC
  MACHINEMAN
  PACKING
}

enum StockEntryMode {
  IN_STOCK
  PACKED
}

enum ProductionStage {
  STAGE_PRESSMAN
  STAGE_UPPERMAN
  STAGE_PRINTING
  STAGE_DC
  STAGE_MACHINEMAN
  STAGE_PACKING
}

enum ProductionOrderSource {
  MANUAL
  PRESSMAN_FLOW
  UPPER_PRINT_PARALLEL
  STAGE_FLOW
}

model Unit {
  id        String   @id @default(uuid())
  name      String   @unique
  symbol    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentTypes PaymentCalculationType[]
  laborRates   LaborRate[]
  laborWork    LaborWorkEntry[]
  materials    MaterialPurchase[]
}

model Article {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  laborRates LaborRate[]
  laborWork  LaborWorkEntry[]
  billLines  BillLine[]
  materials  MaterialPurchase[]
  productionOrders ProductionOrder[]
  stockEntries      StockEntry[]
}

model LaborDepartmentName {
  id         String          @id @default(uuid())
  department LaborDepartment @unique
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model PaymentCalculationType {
  id        String   @id @default(uuid())
  name      String   @unique
  unitId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit   Unit?           @relation(fields: [unitId], references: [id])
  labors LaborProfile[]
}

model Party {
  id             String            @id @default(uuid())
  name           String            @unique
  type           PartyType
  openingBalance Decimal           @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  bills              Bill[]
  ledgerEntries      PartyLedgerEntry[]
  chemicalPurchases  ChemicalPurchase[]
  rexinePurchases    RexinePurchase[]
  materialPurchases  MaterialPurchase[]
  payments           PartyPayment[]
  expenses           ExpenseEntry[]
  receivedCheques    Cheque[]          @relation("ChequeSourceParty")
  usedCheques        Cheque[]          @relation("ChequeUsedParty")
}

model PartyLedgerEntry {
  id             String   @id @default(uuid())
  partyId        String
  billId         String?
  date           DateTime
  reference      String?
  description    String?
  balance        Decimal  @default(0)
  chemicalPurchaseId String?
  rexinePurchaseId   String?
  materialPurchaseId String?
  createdAt      DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id])
  bill  Bill? @relation(fields: [billId], references: [id])
  chemicalPurchase ChemicalPurchase? @relation(fields: [chemicalPurchaseId], references: [id])
  rexinePurchase   RexinePurchase?   @relation(fields: [rexinePurchaseId], references: [id])
  materialPurchase MaterialPurchase? @relation(fields: [materialPurchaseId], references: [id])

  @@index([partyId, date])
}

model ExpenseEntry {
  id                 String        @id @default(uuid())
  date               DateTime
  partyId            String?
  laborId            String?
  module             ExpenseModule @default(MISC)
  paymentType        PaymentMethod @default(CASH)
  amount             Decimal
  description        String?
  chemicalPurchaseId String?
  rexinePurchaseId   String?
  materialPurchaseId String?
  laborAdvanceId     String?
  source             ExpenseSource @default(MANUAL)
  sourceSystem       String?
  createdAt          DateTime      @default(now())

  party             Party?           @relation(fields: [partyId], references: [id])
  labor             LaborProfile?    @relation(fields: [laborId], references: [id])
  chemicalPurchase  ChemicalPurchase? @relation(fields: [chemicalPurchaseId], references: [id])
  rexinePurchase    RexinePurchase?  @relation(fields: [rexinePurchaseId], references: [id])
  materialPurchase  MaterialPurchase? @relation(fields: [materialPurchaseId], references: [id])
  laborAdvance      LaborAdvance?     @relation(fields: [laborAdvanceId], references: [id])

  @@index([date])
}

model LaborProfile {
  id               String                   @id @default(uuid())
  name             String
  department       LaborDepartment          @default(PRESSMAN)
  paymentTypeId    String
  defaultRate      Decimal?
  status           LaborStatus              @default(ACTIVE)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  paymentType  PaymentCalculationType  @relation(fields: [paymentTypeId], references: [id])
  rates        LaborRate[]
  workEntries  LaborWorkEntry[]
  advances     LaborAdvance[]
  expenses     ExpenseEntry[]
  productionOrdersAsMachineman ProductionOrder[] @relation("ProductionOrderMachinemanLabor")
  productionOrdersAsPacking    ProductionOrder[] @relation("ProductionOrderPackingLabor")

  @@index([department])
}

model LaborRate {
  id        String   @id @default(uuid())
  laborId   String
  articleId String
  unitId    String?
  rate      Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  labor   LaborProfile @relation(fields: [laborId], references: [id])
  article Article      @relation(fields: [articleId], references: [id])
  unit    Unit?        @relation(fields: [unitId], references: [id])

  @@unique([laborId, articleId, unitId])
}

model LaborWorkEntry {
  id        String   @id @default(uuid())
  laborId   String
  articleId String
  unitId    String?
  startDate DateTime
  endDate   DateTime
  quantity  Decimal
  rate      Decimal
  total     Decimal
  createdAt DateTime @default(now())

  labor   LaborProfile @relation(fields: [laborId], references: [id])
  article Article      @relation(fields: [articleId], references: [id])
  unit    Unit?        @relation(fields: [unitId], references: [id])

  @@index([laborId, startDate, endDate])
}

model LaborAdvance {
  id             String   @id @default(uuid())
  laborId        String
  date           DateTime
  amount         Decimal
  reason         String?
  createdAt      DateTime @default(now())

  labor   LaborProfile  @relation(fields: [laborId], references: [id])
  expenses ExpenseEntry[]

  @@index([laborId, date])
}

model Bill {
  id         String     @id @default(uuid())
  billNumber String
  date       DateTime
  partyId    String?
  type       BillType   @default(CASH)
  status     BillStatus @default(DRAFT)
  total      Decimal
  verifiedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  party    Party?    @relation(fields: [partyId], references: [id])
  lines    BillLine[]
  payments PartyPayment[]
  ledgerEntries PartyLedgerEntry[]

  @@index([date])
}

model BillLine {
  id        String   @id @default(uuid())
  billId    String
  articleId String
  size      String?
  quantity  Decimal
  price     Decimal
  discount  Decimal  @default(0)
  total     Decimal

  bill    Bill    @relation(fields: [billId], references: [id])
  article Article @relation(fields: [articleId], references: [id])
}

model BillNumberCounter {
  id         String   @id
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@map("bill_number_counter")
}

model StockEntry {
  id            String         @id @default(uuid())
  articleId     String
  mode          StockEntryMode @default(IN_STOCK)
  quantityDozen Decimal
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  article Article @relation(fields: [articleId], references: [id])

  @@index([mode, articleId])
}

model ChemicalPurchase {
  id           String   @id @default(uuid())
  date         DateTime
  partyId      String?
  quantityKg   Decimal
  ratePerKg    Decimal
  totalAmount  Decimal
  paymentType  PaymentMethod @default(CASH)
  createdAt    DateTime      @default(now())

  party     Party?         @relation(fields: [partyId], references: [id])
  expenses  ExpenseEntry[]
  payments  PartyPayment[]
  ledgerEntries PartyLedgerEntry[]

  @@index([date])
}

model RexinePurchase {
  id            String   @id @default(uuid())
  date          DateTime
  partyId       String?
  quantityMeter Decimal
  ratePerMeter  Decimal
  totalAmount   Decimal
  paymentType   PaymentMethod @default(CASH)
  createdAt     DateTime      @default(now())

  party     Party?         @relation(fields: [partyId], references: [id])
  expenses  ExpenseEntry[]
  payments  PartyPayment[]
  ledgerEntries PartyLedgerEntry[]

  @@index([date])
}

model MaterialPurchase {
  id           String   @id @default(uuid())
  date         DateTime
  partyId      String?
  articleId    String?
  unitId       String?
  quantity     Decimal
  pricePerUnit Decimal
  totalAmount  Decimal
  paymentType  PaymentMethod @default(CASH)
  createdAt    DateTime      @default(now())

  party    Party?         @relation(fields: [partyId], references: [id])
  article  Article?       @relation(fields: [articleId], references: [id])
  unit     Unit?          @relation(fields: [unitId], references: [id])
  expenses ExpenseEntry[]
  payments PartyPayment[]
  ledgerEntries PartyLedgerEntry[]

  @@index([date])
}

model PartyPayment {
  id                 String   @id @default(uuid())
  partyId            String
  date               DateTime
  amount             Decimal
  method             PaymentMethod @default(CASH)
  reference          String?
  description        String?
  billId             String?
  chemicalPurchaseId String?
  rexinePurchaseId   String?
  materialPurchaseId String?
  createdAt          DateTime @default(now())

  party             Party             @relation(fields: [partyId], references: [id])
  bill              Bill?             @relation(fields: [billId], references: [id])
  chemicalPurchase  ChemicalPurchase? @relation(fields: [chemicalPurchaseId], references: [id])
  rexinePurchase    RexinePurchase?   @relation(fields: [rexinePurchaseId], references: [id])
  materialPurchase  MaterialPurchase? @relation(fields: [materialPurchaseId], references: [id])
  receivedCheque    Cheque?           @relation("ChequeSourcePayment")
  usedCheque        Cheque?           @relation("ChequeUsedPayment")

  @@index([partyId, date])
}

model Cheque {
  id              String      @id @default(uuid())
  date            DateTime
  amount          Decimal
  chequeNumber    String?
  notes           String?
  status          ChequeStatus @default(AVAILABLE)
  sourcePartyId   String?
  usedPartyId     String?
  sourcePaymentId String?     @unique
  usedPaymentId   String?     @unique
  cashedAt        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sourceParty   Party?       @relation("ChequeSourceParty", fields: [sourcePartyId], references: [id])
  usedParty     Party?       @relation("ChequeUsedParty", fields: [usedPartyId], references: [id])
  sourcePayment PartyPayment? @relation("ChequeSourcePayment", fields: [sourcePaymentId], references: [id])
  usedPayment   PartyPayment? @relation("ChequeUsedPayment", fields: [usedPaymentId], references: [id])

  @@index([status, date])
  @@index([amount])
}

model ProductionOrder {
  id            String                @id @default(uuid())
  department    LaborDepartment
  stage         ProductionStage
  articleId     String
  size          String                @default("")
  laborId       String?
  packingLaborId String?
  quantityDozen Decimal
  pricePerDozen Decimal               @default(0)
  packingPricePerDozen Decimal        @default(0)
  completedDozen Decimal              @default(0)
  bMallDozen    Decimal               @default(0)
  cMallDozen    Decimal               @default(0)
  forwardedDozen Decimal              @default(0)
  source        ProductionOrderSource @default(MANUAL)
  isClosed      Boolean               @default(false)
  closedAt      DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  article Article      @relation(fields: [articleId], references: [id])
  labor   LaborProfile? @relation("ProductionOrderMachinemanLabor", fields: [laborId], references: [id])
  packingLabor LaborProfile? @relation("ProductionOrderPackingLabor", fields: [packingLaborId], references: [id])

  @@index([department, isClosed, updatedAt])
  @@index([articleId, department])
  @@index([packingLaborId])
}


model ChangeLog {
  id        String   @id @default(uuid())
  entity    String
  entityId  String   @map("entity_id")
  operation String
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  synced    Boolean  @default(false)
  deviceId  String   @map("device_id")

  @@index([synced, createdAt])
  @@map("change_log")
}

model SyncState {
  id                String   @id
  lastSyncTimestamp DateTime? @map("last_sync_timestamp")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("sync_state")
}
